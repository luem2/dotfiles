{
 // Place your snippets for sql here. Each snippet is defined under a snippet name and has a prefix, body and 
 // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
 // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
 // same ids are connected.
 // Example:
 // "Print to console": {
 //  "prefix": "log",
 //  "body": [
 //   "console.log('$1');",
 //   "$2"
 //  ],
 //  "description": "Log output to console"
 // }
    "Type Query Insert": {
        "prefix": "typeinsup",
        "body":  [
   "/* Parametros:",
            "   ${4:@ParametroEjemplo} - ${5:explicacion}",
            "*/",
            "-- ${2:0} = ${3:Explicacion del type}",
   "IF (@iType = ${2:0})",
            "BEGIN",
            "    BEGIN TRY",
            "        -- Si no hay una transaccion, iniciamos una:",
            "        IF @@TRANCOUNT = 0",
            "        BEGIN",
            "            BEGIN TRANSACTION ${1:BUSCAR}",
   "",
            "            SET @vTransaccionIniciada = 1",
            "        END",
            "",
            "        $0",
            "",
            "        SET @oError_numero = 0",
            "",
            "        IF @vTransaccionIniciada = 1",
            "            COMMIT TRANSACTION ${1:BUSCAR}",
            "    END TRY",
            "",
            "    BEGIN CATCH",
            "        IF @vTransaccionIniciada = 1",
            "            ROLLBACK TRANSACTION ${1:BUSCAR};",
            "",
            "        THROW",
            "    END CATCH",
            "",
            "    RETURN",
            "END",
  ],
        "description": "Genera la estructura para un type para SP",
    },
    "Type Query Select": {
        "prefix": "typesearch",
        "body":  [
   "/* Parametros:",
            "   ${3:@ParametroEjemplo} - ${4:explicacion}",
            "*/",
            "-- ${1:0} = ${2:Explicacion del type}",
   "IF (@iType = ${1:0})",
            "BEGIN",
            "    $0",
            "",
            "    SET @oError_numero = 0",
            "",
            "    RETURN",
            "END",
  ],
        "description": "Genera la estructura para un type para SP"
    }
}