#!/usr/bin/env bash
set -euo pipefail

DOTFILES_REPO_URL_SSH="git@github.com:luem2/dotfiles.git"
DOTFILES_REPO_URL_HTTPS="https://github.com/luem2/dotfiles.git"
DOTFILES_DIR_DEFAULT="$HOME/.dotfiles"
DOTFILES_DIR="${DOTFILES_DIR:-$DOTFILES_DIR_DEFAULT}"
INSTALL_PATH="$HOME/.local/bin/dotfiles"
GITHUB_SSH_KEY_PATH="$HOME/.ssh/fedora-github"
GIT_SSH_NONINTERACTIVE_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=yes -o PreferredAuthentications=publickey -o IdentitiesOnly=yes -o ConnectTimeout=5"

GITCONFIG_LOCAL_PATH="$HOME/.gitconfig.local"
DOTFILES_BINARY_UPDATED=0

if command -v tput >/dev/null 2>&1 && [ -t 1 ]; then
  BOLD="$(tput bold)"
  RED="$(tput setaf 1)"
  GREEN="$(tput setaf 2)"
  YELLOW="$(tput setaf 3)"
  BLUE="$(tput setaf 4)"
  RESET="$(tput sgr0)"
else
  BOLD=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  RESET=""
fi

ICON_INFO="*"
ICON_OK="+"
ICON_WARN="!"
ICON_ERROR="x"
ICON_PROMPT=">"

log_info() { printf "%b\n" "${BLUE}${ICON_INFO}${RESET} ${BLUE}[INFO]${RESET} $*"; }
log_ok() { printf "%b\n" "${GREEN}${ICON_OK}${RESET} ${GREEN}[OK]${RESET} $*"; }
log_warn() { printf "%b\n" "${YELLOW}${ICON_WARN}${RESET} ${YELLOW}[WARN]${RESET} $*"; }
log_error() { printf "%b\n" "${RED}${ICON_ERROR}${RESET} ${RED}[ERROR]${RESET} $*"; }
log_prompt() { printf "%b" "${BOLD}${YELLOW}${ICON_PROMPT}${RESET} ${BOLD}${YELLOW}[INPUT]${RESET} $*" >&2; }
die() { log_error "$*"; exit 1; }

SUDO_PASS=""

require_sudo() {
  if [ -z "$SUDO_PASS" ]; then
    log_prompt "Sudo password: "
    read -r -s SUDO_PASS </dev/tty
    echo
  fi

  if ! echo "$SUDO_PASS" | sudo -S -v >/dev/null 2>&1; then
    die "sudo authentication failed. Aborting."
  fi
}

ensure_dnf() {
  if ! command -v dnf >/dev/null 2>&1; then
    die "dnf not found. This setup is Fedora-only."
  fi
}

ensure_base_packages() {
  log_info "Installing base packages"
  echo "$SUDO_PASS" | sudo -S dnf install -y git curl jq unzip ansible stow
}

run_dankinstall() {
  if command -v niri >/dev/null 2>&1 && command -v dms >/dev/null 2>&1; then
    log_info "Niri and DMS already installed; skipping dankinstall."
    return 0
  fi

  log_info "Running official Dank installer (https://install.danklinux.com)"
  if ! curl -fsSL https://install.danklinux.com | bash; then
    die "official dankinstall failed"
  fi
}

git_ssh_command() {
  local ssh_command="ssh $GIT_SSH_NONINTERACTIVE_OPTS"

  if [ -f "$GITHUB_SSH_KEY_PATH" ]; then
    ssh_command="$ssh_command -i $GITHUB_SSH_KEY_PATH"
  fi

  printf '%s\n' "$ssh_command"
}

ensure_github_known_host() {
  mkdir -p "$HOME/.ssh"
  touch "$HOME/.ssh/known_hosts"
  chmod 700 "$HOME/.ssh"
  chmod 600 "$HOME/.ssh/known_hosts"

  if ! ssh-keygen -F github.com -f "$HOME/.ssh/known_hosts" >/dev/null 2>&1; then
    ssh-keyscan -H github.com >>"$HOME/.ssh/known_hosts" 2>/dev/null || die "failed to add github.com to known_hosts"
  fi
}

ssh_repo_access_ok() {
  ensure_github_known_host
  GIT_SSH_COMMAND="$(git_ssh_command)" git ls-remote --exit-code "$DOTFILES_REPO_URL_SSH" HEAD >/dev/null 2>&1
}

switch_origin_to_ssh_if_available() {
  local current_origin
  current_origin="$(git -C "$DOTFILES_DIR" remote get-url origin 2>/dev/null || true)"
  if [ "$current_origin" = "$DOTFILES_REPO_URL_HTTPS" ] && ssh_repo_access_ok; then
    log_info "SSH access detected. Switching dotfiles origin to SSH."
    git -C "$DOTFILES_DIR" remote set-url origin "$DOTFILES_REPO_URL_SSH"
  fi
}

ensure_repo() {
  if [ -d "$DOTFILES_DIR/.git" ]; then
    switch_origin_to_ssh_if_available
    log_info "Updating dotfiles repo"
    if ! GIT_SSH_COMMAND="$(git_ssh_command)" git -C "$DOTFILES_DIR" pull --quiet --ff-only; then
      local current_origin
      current_origin="$(git -C "$DOTFILES_DIR" remote get-url origin 2>/dev/null || true)"
      if [ "$current_origin" = "$DOTFILES_REPO_URL_SSH" ]; then
        log_warn "SSH pull failed, switching origin to HTTPS and retrying"
        git -C "$DOTFILES_DIR" remote set-url origin "$DOTFILES_REPO_URL_HTTPS"
        git -C "$DOTFILES_DIR" pull --quiet --ff-only || die "failed to update dotfiles repo via HTTPS"
      else
        die "failed to update dotfiles repo"
      fi
    fi
  else
    log_info "Cloning dotfiles repo"
    ensure_github_known_host
    if ! GIT_SSH_COMMAND="$(git_ssh_command)" git clone --quiet "$DOTFILES_REPO_URL_SSH" "$DOTFILES_DIR"; then
      log_warn "SSH clone failed, retrying with HTTPS"
      git clone --quiet "$DOTFILES_REPO_URL_HTTPS" "$DOTFILES_DIR" || die "failed to clone dotfiles repo"
    fi
  fi
}

install_dotfiles_binary() {
  mkdir -p "$(dirname "$INSTALL_PATH")"
  if [ -f "$DOTFILES_DIR/bin/dotfiles" ]; then
    if [ ! -f "$INSTALL_PATH" ] || ! cmp -s "$DOTFILES_DIR/bin/dotfiles" "$INSTALL_PATH"; then
      install -m 0755 "$DOTFILES_DIR/bin/dotfiles" "$INSTALL_PATH"
      DOTFILES_BINARY_UPDATED=1
    fi
  fi
}

reexec_if_binary_updated() {
  if [ "$DOTFILES_BINARY_UPDATED" -eq 1 ] && [ "${DOTFILES_REEXEC:-0}" != "1" ]; then
    log_info "Relaunching dotfiles with updated launcher."
    export DOTFILES_REEXEC=1
    export SUDO_PASS
    exec "$INSTALL_PATH" "$@"
  fi
}

run_ansible() {
  log_info "Running Ansible playbook"
  ANSIBLE_FORCE_COLOR=1 ANSIBLE_BECOME_PASS="$SUDO_PASS" ansible-playbook -v -i localhost, -c local "$DOTFILES_DIR/bootstrap.yml"
}

prompt_value() {
  local prompt="$1"
  local default="${2:-}"
  local value=""

  while true; do
    if [ -n "$default" ]; then
      log_prompt "$prompt [$default]: "
      read -r value </dev/tty
      value="${value:-$default}"
    else
      log_prompt "$prompt: "
      read -r value </dev/tty
    fi

    if [ -n "$value" ]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
}

ensure_gitconfig_local() {
  local local_name local_email
  local_name="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.name 2>/dev/null || true)"
  local_email="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.email 2>/dev/null || true)"

  if [ -f "$GITCONFIG_LOCAL_PATH" ] && [ -n "$local_email" ]; then
    return 0
  fi

  log_info "Configuring Git identity"
  local current_name current_email git_name git_email
  current_name="$(git config --global --get user.name 2>/dev/null || true)"
  current_email="$(git config --global --get user.email 2>/dev/null || true)"

  log_info "Step 1/2: Enter your Git username (user.name). Example: John Doe"
  git_name="$(prompt_value "Git user.name" "${local_name:-${current_name:-$USER}}")"

  log_info "Step 2/2: Enter your Git email (user.email). Example: john@company.com"
  while true; do
    git_email="$(prompt_value "Git user.email" "${local_email:-$current_email}")"
    if [[ "$git_email" == *"@"* ]]; then
      break
    fi
    log_warn "Invalid email format. Use a valid email for Git commits (example: john@company.com)."
  done

  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.name "$git_name"
  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.email "$git_email"
  chmod 600 "$GITCONFIG_LOCAL_PATH"
  log_ok "Generated $GITCONFIG_LOCAL_PATH"
}

run_stow() {
  if [ ! -d "$DOTFILES_DIR/roles" ]; then
    return 0
  fi

  local had_conflicts=0
  local package_name

  log_info "Applying Stow packages"
  while IFS= read -r -d '' package_dir; do
    package_name="${package_dir##*/}"
    if ! (cd "$DOTFILES_DIR/roles" && stow -d "$DOTFILES_DIR/roles" -t "$HOME" --no-folding -R "$package_name"); then
      had_conflicts=1
      log_warn "Stow skipped package '$package_name' due to conflicts."
    fi
  done < <(find "$DOTFILES_DIR/roles" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

  if [ "$had_conflicts" -eq 1 ]; then
    log_warn "Some packages were skipped due to conflicts."
    log_warn "Fix conflicts and rerun."
  fi
}

main() {
  log_info "Starting dotfiles"
  require_sudo
  ensure_dnf
  ensure_base_packages
  ensure_repo
  install_dotfiles_binary
  reexec_if_binary_updated "$@"
  run_dankinstall
  ensure_gitconfig_local
  run_ansible
  run_stow
  unset SUDO_PASS
  log_ok "Instalacion/Actualizacion del sistema exitosamente."
}

main "$@"
