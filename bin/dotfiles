#!/usr/bin/env bash
set -euo pipefail

DOTFILES_REPO_URL="git@github.com:luem2/dotfiles.git"
DOTFILES_DIR_DEFAULT="$HOME/.dotfiles"
DOTFILES_DIR="${DOTFILES_DIR:-$DOTFILES_DIR_DEFAULT}"
INSTALL_PATH="$HOME/.local/bin/dotfiles"

SSH_DIR="$HOME/.ssh"
SSH_CONFIG_BW="$SSH_DIR/config"
GITCONFIG_LOCAL_PATH="$HOME/.gitconfig.local"

RBW_CONFIG_ITEM="ssh-config"
RBW_KEY_SUFFIX="_SSH"

if command -v tput >/dev/null 2>&1 && [ -t 1 ]; then
  BOLD="$(tput bold)"
  RED="$(tput setaf 1)"
  GREEN="$(tput setaf 2)"
  YELLOW="$(tput setaf 3)"
  BLUE="$(tput setaf 4)"
  RESET="$(tput sgr0)"
else
  BOLD=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  RESET=""
fi

ICON_INFO="*"
ICON_OK="+"
ICON_WARN="!"
ICON_ERROR="x"
ICON_PROMPT=">"

log_info() { printf "%b\n" "${BLUE}${ICON_INFO}${RESET} ${BLUE}[INFO]${RESET} $*"; }
log_ok() { printf "%b\n" "${GREEN}${ICON_OK}${RESET} ${GREEN}[OK]${RESET} $*"; }
log_warn() { printf "%b\n" "${YELLOW}${ICON_WARN}${RESET} ${YELLOW}[WARN]${RESET} $*"; }
log_error() { printf "%b\n" "${RED}${ICON_ERROR}${RESET} ${RED}[ERROR]${RESET} $*"; }
log_prompt() { printf "%b" "${BOLD}${YELLOW}${ICON_PROMPT}${RESET} ${BOLD}${YELLOW}[INPUT]${RESET} $*"; }
die() { log_error "$*"; exit 1; }

SUDO_PASS=""

require_sudo() {
  if [ -z "$SUDO_PASS" ]; then
    log_prompt "Sudo password: "
    read -r -s SUDO_PASS </dev/tty
    echo
  fi

  if ! echo "$SUDO_PASS" | sudo -S -v >/dev/null 2>&1; then
    die "sudo authentication failed. Aborting."
  fi
}

ensure_dnf() {
  if ! command -v dnf >/dev/null 2>&1; then
    die "dnf not found. This setup is Fedora-only."
  fi
}

ensure_base_packages() {
  log_info "Installing base packages"
  echo "$SUDO_PASS" | sudo -S dnf install -y git curl jq unzip ansible stow
}

ensure_rbw() {
  if command -v rbw >/dev/null 2>&1; then
    return 0
  fi

  log_info "Installing rbw"
  echo "$SUDO_PASS" | sudo -S dnf install -y rbw
}

ensure_repo() {
  if [ -d "$DOTFILES_DIR/.git" ]; then
    log_info "Updating dotfiles repo"
    git -C "$DOTFILES_DIR" pull --quiet --ff-only
  else
    log_info "Cloning dotfiles repo"
    git clone --quiet "$DOTFILES_REPO_URL" "$DOTFILES_DIR"
  fi
}

install_dotfiles_binary() {
  mkdir -p "$(dirname "$INSTALL_PATH")"
  if [ -f "$DOTFILES_DIR/bin/dotfiles" ]; then
    if [ ! -f "$INSTALL_PATH" ] || ! cmp -s "$DOTFILES_DIR/bin/dotfiles" "$INSTALL_PATH"; then
      install -m 0755 "$DOTFILES_DIR/bin/dotfiles" "$INSTALL_PATH"
    fi
  fi
}

rbw_sync() {
  rbw sync >/dev/null 2>&1 || rbw login
  rbw unlock >/dev/null 2>&1 || true
}

restore_ssh_keys() {
  log_info "Restoring SSH keys from Bitwarden (rbw notes)"
  mkdir -p "$SSH_DIR"
  chmod 700 "$SSH_DIR"

  rbw ls | while read -r item_name; do
    [ -n "$item_name" ] || continue
    case "$item_name" in
      *"$RBW_KEY_SUFFIX")
        local key_name private_key key_path
        key_name=$(printf '%s' "$item_name" | sed 's/[^a-zA-Z0-9_-]/_/g' | sed "s/${RBW_KEY_SUFFIX}$//")
        private_key=$(rbw get --field=notes "$item_name" 2>/dev/null || true)
        [ -n "$private_key" ] || continue
        key_path="$SSH_DIR/$key_name"
        if [ -f "$key_path" ]; then
          if [ ! -s "$key_path" ]; then
            printf '%s\n' "$private_key" >"$key_path"
          fi
          chmod 600 "$key_path"
          continue
        fi
        printf '%s\n' "$private_key" >"$key_path"
        chmod 600 "$key_path"
        ;;
      *)
        ;;
    esac
  done
}

restore_ssh_config() {
  log_info "Restoring SSH config from Bitwarden (rbw notes)"
  local config_text
  config_text=$(rbw get --field=notes "$RBW_CONFIG_ITEM" 2>/dev/null || true)
  if [ -z "$config_text" ]; then
    log_error "Bitwarden item '$RBW_CONFIG_ITEM' notes not found."
    return 1
  fi
  printf '%s\n' "$config_text" >"$SSH_CONFIG_BW"
  chmod 600 "$SSH_CONFIG_BW"
}

run_ansible() {
  log_info "Running Ansible playbook"
  ANSIBLE_FORCE_COLOR=1 ANSIBLE_BECOME_PASS="$SUDO_PASS" ansible-playbook -v -i localhost, -c local "$DOTFILES_DIR/bootstrap.yml"
}

prompt_value() {
  local prompt="$1"
  local default="${2:-}"
  local value=""

  while true; do
    if [ -n "$default" ]; then
      log_prompt "$prompt [$default]: "
      read -r value </dev/tty
      value="${value:-$default}"
    else
      log_prompt "$prompt: "
      read -r value </dev/tty
    fi

    if [ -n "$value" ]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
}

ensure_gitconfig_local() {
  local local_name local_email
  local_name="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.name 2>/dev/null || true)"
  local_email="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.email 2>/dev/null || true)"

  if [ -f "$GITCONFIG_LOCAL_PATH" ] && [ -n "$local_email" ]; then
    return 0
  fi

  log_info "Configuring Git identity"
  log_prompt "Please enter your Git user.name and user.email."
  echo
  local current_name current_email git_name git_email
  current_name="$(git config --global --get user.name 2>/dev/null || true)"
  current_email="$(git config --global --get user.email 2>/dev/null || true)"

  git_name="$(prompt_value "Git user.name" "${local_name:-${current_name:-$USER}}")"

  while true; do
    git_email="$(prompt_value "Git user.email" "${local_email:-$current_email}")"
    if [[ "$git_email" == *"@"* ]]; then
      break
    fi
    log_warn "Invalid email format. Please try again."
  done

  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.name "$git_name"
  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.email "$git_email"
  chmod 600 "$GITCONFIG_LOCAL_PATH"
  log_ok "Generated $GITCONFIG_LOCAL_PATH"
}

run_stow() {
  if [ ! -d "$DOTFILES_DIR/roles" ]; then
    return 0
  fi

  log_info "Applying Stow packages"
  (cd "$DOTFILES_DIR/roles" && stow -d "$DOTFILES_DIR/roles" -t "$HOME" --adopt -R */)
}

main() {
  log_info "Starting dotfiles"
  require_sudo
  ensure_dnf
  ensure_base_packages
  ensure_rbw
  ensure_repo
  install_dotfiles_binary
  if [ "${SKIP_BITWARDEN:-}" = "1" ]; then
    log_warn "Skipping Bitwarden restore (SKIP_BITWARDEN=1)"
  else
    rbw_sync
    restore_ssh_keys
    restore_ssh_config
  fi
  ensure_gitconfig_local
  run_ansible
  run_stow
  unset SUDO_PASS
  log_ok "Dotfiles applied successfully."
  log_info "Rebooting in 10 seconds. Press any key to reboot now, or press 'c' to cancel."
  if read -r -n 1 -t 10 key </dev/tty; then
    if [ "$key" = "c" ] || [ "$key" = "C" ]; then
      log_warn "Reboot cancelled."
      return 0
    fi
  fi
  echo "$SUDO_PASS" | sudo -S reboot
}

main "$@"
