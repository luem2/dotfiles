#!/usr/bin/env bash
set -euo pipefail

INSTALL_PATH="$HOME/.local/bin/dotfiles"

GITCONFIG_LOCAL_PATH="$HOME/.gitconfig.local"

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"

  while [ -L "$source_path" ]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    if [[ "$source_path" != /* ]]; then
      source_path="$source_dir/$source_path"
    fi
  done

  cd -P "$(dirname "$source_path")" && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if command -v tput >/dev/null 2>&1 && [ -t 1 ]; then
  BOLD="$(tput bold)"
  RED="$(tput setaf 1)"
  GREEN="$(tput setaf 2)"
  YELLOW="$(tput setaf 3)"
  BLUE="$(tput setaf 4)"
  RESET="$(tput sgr0)"
else
  BOLD=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  RESET=""
fi

ICON_INFO="*"
ICON_OK="+"
ICON_WARN="!"
ICON_ERROR="x"
ICON_PROMPT=">"

log_info() { printf "%b\n" "${BLUE}${ICON_INFO}${RESET} ${BLUE}[INFO]${RESET} $*"; }
log_ok() { printf "%b\n" "${GREEN}${ICON_OK}${RESET} ${GREEN}[OK]${RESET} $*"; }
log_warn() { printf "%b\n" "${YELLOW}${ICON_WARN}${RESET} ${YELLOW}[WARN]${RESET} $*"; }
log_error() { printf "%b\n" "${RED}${ICON_ERROR}${RESET} ${RED}[ERROR]${RESET} $*"; }
log_prompt() { printf "%b" "${BOLD}${YELLOW}${ICON_PROMPT}${RESET} ${BOLD}${YELLOW}[INPUT]${RESET} $*" >&2; }
die() { log_error "$*"; exit 1; }

SUDO_PASS=""

require_sudo() {
  if [ -z "$SUDO_PASS" ]; then
    log_prompt "Sudo password: "
    read -r -s SUDO_PASS </dev/tty
    echo
  fi

  if ! echo "$SUDO_PASS" | sudo -S -v >/dev/null 2>&1; then
    die "sudo authentication failed. Aborting."
  fi
}

ensure_dnf() {
  if ! command -v dnf >/dev/null 2>&1; then
    die "dnf not found. This setup is Fedora-only."
  fi
}

ensure_base_packages() {
  log_info "Installing base packages"
  echo "$SUDO_PASS" | sudo -S dnf install -y git curl jq unzip ansible stow
}

run_dankinstall() {
  if command -v niri >/dev/null 2>&1 && command -v dms >/dev/null 2>&1; then
    log_info "Niri and DMS already installed; skipping dankinstall."
    return 0
  fi

  log_info "Running official Dank installer (https://install.danklinux.com)"
  if ! curl -fsSL https://install.danklinux.com | bash; then
    die "official dankinstall failed"
  fi
}

ensure_repo_layout() {
  if [ ! -f "$DOTFILES_DIR/bootstrap.yml" ] || [ ! -d "$DOTFILES_DIR/roles" ]; then
    die "dotfiles repo not found at $DOTFILES_DIR. Run this script from the cloned repository or symlink $INSTALL_PATH to $DOTFILES_DIR/bin/dotfiles."
  fi
}

install_dotfiles_symlink() {
  local source_script="$DOTFILES_DIR/bin/dotfiles"

  mkdir -p "$(dirname "$INSTALL_PATH")"
  if [ ! -L "$INSTALL_PATH" ] || [ "$(readlink -f "$INSTALL_PATH" 2>/dev/null || true)" != "$source_script" ]; then
    ln -snf "$source_script" "$INSTALL_PATH"
  fi
}

run_ansible() {
  log_info "Running Ansible playbook"
  ANSIBLE_FORCE_COLOR=1 ANSIBLE_BECOME_PASS="$SUDO_PASS" ansible-playbook -v -i localhost, -c local "$DOTFILES_DIR/bootstrap.yml"
}

prompt_value() {
  local prompt="$1"
  local default="${2:-}"
  local value=""

  while true; do
    if [ -n "$default" ]; then
      log_prompt "$prompt [$default]: "
      read -r value </dev/tty
      value="${value:-$default}"
    else
      log_prompt "$prompt: "
      read -r value </dev/tty
    fi

    if [ -n "$value" ]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
}

ensure_gitconfig_local() {
  local local_name local_email
  local_name="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.name 2>/dev/null || true)"
  local_email="$(git config --file "$GITCONFIG_LOCAL_PATH" --get user.email 2>/dev/null || true)"

  if [ -f "$GITCONFIG_LOCAL_PATH" ] && [ -n "$local_email" ]; then
    return 0
  fi

  log_info "Configuring Git identity"
  local current_name current_email git_name git_email
  current_name="$(git config --global --get user.name 2>/dev/null || true)"
  current_email="$(git config --global --get user.email 2>/dev/null || true)"

  log_info "Step 1/2: Enter your Git username (user.name). Example: John Doe"
  git_name="$(prompt_value "Git user.name" "${local_name:-${current_name:-$USER}}")"

  log_info "Step 2/2: Enter your Git email (user.email). Example: john@company.com"
  while true; do
    git_email="$(prompt_value "Git user.email" "${local_email:-$current_email}")"
    if [[ "$git_email" == *"@"* ]]; then
      break
    fi
    log_warn "Invalid email format. Use a valid email for Git commits (example: john@company.com)."
  done

  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.name "$git_name"
  git config --file "$GITCONFIG_LOCAL_PATH" --replace-all user.email "$git_email"
  chmod 600 "$GITCONFIG_LOCAL_PATH"
  log_ok "Generated $GITCONFIG_LOCAL_PATH"
}

run_stow() {
  if [ ! -d "$DOTFILES_DIR/roles" ]; then
    return 0
  fi

  local had_conflicts=0
  local package_name

  log_info "Applying Stow packages"
  while IFS= read -r -d '' package_dir; do
    package_name="${package_dir##*/}"
    if ! (cd "$DOTFILES_DIR/roles" && stow -d "$DOTFILES_DIR/roles" -t "$HOME" --no-folding -R "$package_name"); then
      had_conflicts=1
      log_warn "Stow skipped package '$package_name' due to conflicts."
    fi
  done < <(find "$DOTFILES_DIR/roles" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

  if [ "$had_conflicts" -eq 1 ]; then
    log_warn "Some packages were skipped due to conflicts."
    log_warn "Fix conflicts and rerun."
  fi
}

main() {
  log_info "Starting dotfiles"
  ensure_repo_layout
  require_sudo
  ensure_dnf
  ensure_base_packages
  install_dotfiles_symlink
  run_dankinstall
  ensure_gitconfig_local
  run_ansible
  run_stow
  unset SUDO_PASS
  log_ok "Instalacion/Actualizacion del sistema exitosamente."
}

main "$@"
